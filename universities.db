-- страны
CREATE TABLE countries (
    id   INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE
);

-- направления
CREATE TABLE fields (
    id   INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE
);

-- вузы
CREATE TABLE universities (
    id           INTEGER PRIMARY KEY AUTOINCREMENT,
    name         TEXT    NOT NULL,
    country_id   INTEGER NOT NULL REFERENCES countries(id),
    city         TEXT    NOT NULL,
    ielts_min    REAL    NOT NULL,
    gpa_min      REAL    NOT NULL,
    tuition_usd  INTEGER NOT NULL DEFAULT 0,
    scholarship  INTEGER NOT NULL DEFAULT 0,
    url          TEXT    NOT NULL
);

-- связи
CREATE TABLE university_fields (
    university_id INTEGER NOT NULL REFERENCES universities(id),
    field_id      INTEGER NOT NULL REFERENCES fields(id),
    PRIMARY KEY (university_id, field_id)
);

-- индексы
CREATE INDEX idx_uni_country   ON universities(country_id);
CREATE INDEX idx_uni_ielts     ON universities(ielts_min);
CREATE INDEX idx_uni_gpa       ON universities(gpa_min);
CREATE INDEX idx_uni_tuition   ON universities(tuition_usd);
CREATE INDEX idx_uni_fields    ON university_fields(field_id);

